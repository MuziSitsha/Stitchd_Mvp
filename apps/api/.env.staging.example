# ============================================
# STITCHD API - Staging Environment Template
# Account owner email: sales@gubudo.com
# Copy to .env.staging or your secret manager
# ============================================

# App
NODE_ENV=staging
PORT=3001
PUBLIC_API_URL=https://api-staging.example.com

# JWT
JWT_SECRET=replace-with-staging-jwt-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# PostgreSQL
DATABASE_URL=postgresql://stitchd_app:[PASSWORD]@[HOST]:5432/kazi_staging

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Clickatell
CLICKATELL_API_KEY=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# PayFast
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_MODE=test

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=stitchd-staging-uploads

# Commission
DEFAULT_COMMISSION_RATE=0.15

# CORS
ALLOWED_ORIGINS=https://admin-staging.example.com,http://localhost:5173